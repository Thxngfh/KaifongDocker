# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง (ห้าม commit ไฟล์ .env ขึ้น git)
# คำสั่ง: cp .env.example .env   (Windows: copy .env.example .env)

# เชื่อมต่อฐานข้อมูล PostgreSQL — ขอค่าจริงจากทีม DB
DATABASE_URL=postgresql://user:password@host:port/database

# Token จริงจาก LINE Developers Console > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# Origin ที่อนุญาตให้เรียก API ได้ คั่นด้วย comma
# เช่น domain ของ LIFF frontend บน Vercel + localhost สำหรับทดสอบ
ALLOWED_ORIGINS=http://localhost:8000,https://your-liff-domain.vercel.app